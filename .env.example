OLLAMA_BASE_URL=http://127.0.0.1:11434
MODEL_UTILITY=ollama/llama3.1:8b
MODEL_CREATIVE=ollama/qwen2.5:14b

NOTION_TOKEN=
NOTION_DB_ID=

# Scout extras (optional — empty = skip the source)
# Reddit: register a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=RoyalPopBot/1.0
# Brave Search API free tier: https://brave.com/search/api/ — 2000 q/mo
BRAVE_API_KEY=

# ─────────────────────────────────────────────────────────────
# Cloud LLM providers (free tiers) — pipeline_config.py routes
# per-agent. Empty key = agent falls back to Ollama.
# ─────────────────────────────────────────────────────────────

# Groq — fast Llama 3.3 70B + Qwen-QwQ. Free 30 req/min.
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=

# Mistral La Plateforme — Mistral Large + Small. Free tier.
# Sign up: https://console.mistral.ai/
MISTRAL_API_KEY=

# Google AI Studio — Gemini 2.0 Flash + 2.5 Pro. Free 15 RPM Flash, 2 RPM Pro.
# Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional override — set to bypass pipeline_config and force all agents
# to one provider for a single run. Leave blank in normal use.
PWS_PROVIDER_OVERRIDE=
PWS_MODEL_OVERRIDE=
